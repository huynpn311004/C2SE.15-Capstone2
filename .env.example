
# JWT Secret (generate with openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS origins
ALLOWED_HOSTS=localhost,127.0.0.1

# VNPay Payment Gateway (Sandbox - Đăng ký tại https://sandbox.vnpayment.vn)
VNP_TMNCODE=YOUR_TMN_CODE
VNP_HASH_SECRET=YOUR_HASH_SECRET
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5173/payment/vnpay/return

# Production VNPay (thay đổi khi deploy)
# VNPAY_URL=https://pay.vnpay.vn/vpcpay.html

# Email config (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Run: cp .env.example .env và chỉnh sửa thông tin cá nhân

